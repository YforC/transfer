<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">
<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/">
	<appender name="RollingFile" class="org.apache.log4j.RollingFileAppender">
		<param name="File" value="logs/cgw.log" />
		<param name="Append" value="true" />
		<param name="MaxFileSize" value="10MB" />
		<param name="MaxBackupIndex" value="10" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5p] %m(%c:%M:%L)[%t]%n" />
		</layout>
	</appender>
	<appender name="DailyRolling" class="org.apache.log4j.DailyRollingFileAppender">
		<param name="File" value="logs/web.log" />
		<param name="Append" value="true" />
		<param name="datePattern" value="'.'yyyy-MM-dd" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5p] %m(%c:%M:%L)[%t]%n" />
		</layout>
	</appender>
	<appender name="STDOUT" class="org.apache.log4j.ConsoleAppender">
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5p] %m(%c:%M:%L)[%t]%n" />
		</layout>
	</appender>
	<logger additivity="true" name="com.weather">
		<level value="debug" />
		<appender-ref ref="DailyRolling" />
	</logger>
	<root>
		<priority value="warn" />
		<appender-ref ref="STDOUT" />
	</root>
</log4j:configuration>
