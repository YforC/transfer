<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-3.0.xsd">

    <import resource="applicationContext-cxf-server.xml"/>
    <context:property-placeholder location="classpath:db.properties"/>
    <context:annotation-config/>

    <bean id="mobileDataSource" class="org.springframework.jdbc.datasource.DriverManagerDataSource">
        <property name="driverClassName" value="${mobile.database.driverClassName}"/>
        <property name="url" value="${mobile.database.url}"/>
        <property name="username" value="${mobile.database.username}"/>
        <property name="password" value="${mobile.database.password}"/>
    </bean>

    <bean id="unicomDataSource" class="org.springframework.jdbc.datasource.DriverManagerDataSource">
        <property name="driverClassName" value="${unicom.database.driverClassName}"/>
        <property name="url" value="${unicom.database.url}"/>
        <property name="username" value="${unicom.database.username}"/>
        <property name="password" value="${unicom.database.password}"/>
    </bean>

    <bean id="mobileJdbcTemplate" class="org.springframework.jdbc.core.JdbcTemplate">
        <property name="dataSource" ref="mobileDataSource"/>
    </bean>

    <bean id="unicomJdbcTemplate" class="org.springframework.jdbc.core.JdbcTemplate">
        <property name="dataSource" ref="unicomDataSource"/>
    </bean>

    <bean id="mobileCellPhoneInfoRepository" class="com.unicom.repository.CellPhoneInfoRepository">
        <constructor-arg ref="mobileJdbcTemplate"/>
    </bean>

    <bean id="unicomCellPhoneInfoRepository" class="com.unicom.repository.CellPhoneInfoRepository">
        <constructor-arg ref="unicomJdbcTemplate"/>
    </bean>

    <bean id="telecomTransferGatewayService" class="com.unicom.service.TelecomTransferGatewayService">
        <constructor-arg value="${telecom.transfer.service.address}"/>
    </bean>
</beans>
